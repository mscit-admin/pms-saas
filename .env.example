# ====== اتصال جيرا (Jira Cloud) ======
# Basic Auth: البريد + API Token. لا يُتصل بجيرا من المتصفح إطلاقاً — فقط الخلفية.
# أنشئ التوكن من: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_api_token_here

# JQL الأساسي لسحب التذاكر. مثال: مشروع محدد + غير المنجزة + المنجزة حديثاً
# اتركه فارغاً لاستخدام الافتراضي في الكود.
JIRA_JQL=project = OPS ORDER BY updated DESC

# مسار نقطة البحث الجديدة (القديمة /rest/api/3/search أُزيلت — 410).
JIRA_SEARCH_PATH=/rest/api/3/search/jql

# عدد التذاكر لكل صفحة عند السحب
JIRA_PAGE_SIZE=100

# ====== قاعدة البيانات (MySQL 8+) ======
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=jira_monitor
DB_PASSWORD=change_me
DB_NAME=jira_monitor
DB_CONNECTION_LIMIT=10

# ====== المزامنة (Polling) ======
# الفترة بين عمليات السحب بالدقائق
SYNC_INTERVAL_MINUTES=5
# توكن سري لحماية مسار /api/sync عند تشغيله من مجدول خارجي
SYNC_SECRET=change_me_too

# سرّ مستقبِل Webhooks من جيرا (يرجع لـ SYNC_SECRET إن تُرك فارغاً)
WEBHOOK_SECRET=change_me_webhook

# ====== المصادقة (مستخدمون + أدوار + 2FA) ======
# سرّ توقيع جلسات الدخول (JWT). اجعله طويلاً وعشوائياً.
SESSION_SECRET=change_me_long_random_session_secret
# كلمة مرور المستخدم admin الأولي (تُستخدم مرة عند seed:admin)
ADMIN_INITIAL_PASSWORD=change_me_admin
# اجعلها true فقط بعد تفعيل HTTPS (وإلا لن يُحفظ كوكي الجلسة عبر HTTP)
COOKIE_SECURE=false

# ====== تطبيق تغيير المنفذ تلقائياً ======
# الأمر الذي يُشغَّل بعد حفظ منفذ جديد (يعيد تشغيل الخدمة ويحدّث nginx).
# اتركه فارغاً لتعطيل إعادة التشغيل التلقائي. الافتراضي:
# PORT_APPLY_CMD=sudo /usr/local/bin/jem-apply-port

# ====== قواعد الاستثناء (أيام) — قابلة للضبط ======
RULE_STAGNANT_DAYS=3
RULE_REVIEW_DAYS=2

# ====== SLA حسب الأولوية (أيام) — قابلة للضبط ======
# تُستخدم كقيم بذرية عند تهيئة جدول sla_config، والمصدر الحقيقي هو الجدول.
SLA_HIGH_DAYS=7
SLA_MEDIUM_DAYS=14
SLA_LOW_DAYS=21
