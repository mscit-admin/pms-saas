[Unit]
Description=Jira Exception Monitor - Web (Next.js)
After=network.target mysql.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/GHProjects/jira-monitor
Environment=NODE_ENV=production
Environment=PORT=4445
# يَكتب التطبيق المنفذ الجديد هنا عند تغييره من الواجهة (يتجاوز PORT أعلاه)
EnvironmentFile=-/GHProjects/jira-monitor/port.env
ExecStart=/usr/bin/npm run start
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
