{
  "name": "pms-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PMS — مراقب جيرا، معماريّة خدمات مصغّرة (واجهة / API / عامل مزامنة) فوق منطق مشترك",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "db:migrate": "npm run db:migrate -w @pms/core",
    "seed:admin": "npm run seed:admin -w @pms/core",
    "jira:sync": "npm run jira:sync -w @pms/core",
    "jira:backfill": "npm run jira:backfill -w @pms/core",
    "digest": "npm run digest -w @pms/core",
    "dev:web": "npm run dev -w @pms/web",
    "dev:api": "npm run dev -w @pms/api",
    "dev:worker": "npm run start -w @pms/worker",
    "build:web": "npm run build -w @pms/web"
  },
  "engines": {
    "node": ">=20"
  }
}
