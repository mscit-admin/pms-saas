# إعدادات تشغيل الخدمات المصغّرة عبر docker compose.
# انسخه إلى .env واملأ القيم:  cp .env.docker.example .env

# ---- قاعدة البيانات (خادم MySQL مشترك؛ قاعدة مستقلّة لكل مستأجر) ----
DB_USER=root
DB_PASSWORD=change-me-strong
DB_CONNECTION_LIMIT=10
# DB_NAME للتطوير الأحادي فقط (لم يعد يُستخدم في وضع الـ SaaS)
DB_NAME=jira_monitor

# ---- تعدّد المستأجرين (SaaS) ----
CONTROL_DB_NAME=pms_control
# النطاق الجذر: منه يُستخرج النطاق الفرعي (acme.example.com ⇒ slug=acme)
APP_ROOT_DOMAIN=example.com
TENANT_DB_PREFIX=tenant_
# منظمة افتراضية تُوفَّر تلقائياً عند الإقلاع (اتركها فارغة لتعطيلها):
BOOTSTRAP_TENANT_SLUG=acme
BOOTSTRAP_TENANT_NAME=Acme Inc
ADMIN_INITIAL_PASSWORD=change-me-admin-pass
# وضع المستأجر الافتراضي: عند الوصول بلا نطاق فرعي (IP عارٍ) يقع النظام على هذه
# المنظمة. اضبطه للنشر بعنوان IP فقط أو خلف شبكة تحجب nip.io. اتركه فارغاً
# لفرض النطاقات الفرعية فقط (إنتاج SaaS حقيقي).
DEFAULT_TENANT_SLUG=acme

# ---- أسرار الجلسة/المزامنة ----
SESSION_SECRET=change-me-32+chars-random
SYNC_SECRET=change-me-sync-secret
WEBHOOK_SECRET=change-me-webhook-secret
# فعّل الكوكي الآمن فقط خلف HTTPS
COOKIE_SECURE=false

# ---- منفذ الواجهة على المضيف ----
WEB_PORT=4447

# ---- المزامنة ----
SYNC_INTERVAL_MINUTES=5

# ---- جيرا (اختياري؛ يمكن ضبطه لاحقاً من الإعدادات داخل التطبيق) ----
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_JQL=ORDER BY updated DESC
