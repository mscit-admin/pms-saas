# إعدادات تشغيل الخدمات المصغّرة عبر docker compose.
# انسخه إلى .env واملأ القيم:  cp .env.docker.example .env

# ---- قاعدة البيانات (المستخدمة من db + api + worker + migrate) ----
DB_NAME=jira_monitor
DB_USER=root
DB_PASSWORD=change-me-strong
DB_CONNECTION_LIMIT=10

# ---- أسرار الجلسة/المزامنة ----
SESSION_SECRET=change-me-32+chars-random
SYNC_SECRET=change-me-sync-secret
WEBHOOK_SECRET=change-me-webhook-secret
# فعّل الكوكي الآمن فقط خلف HTTPS
COOKIE_SECURE=false

# ---- منفذ الواجهة على المضيف ----
WEB_PORT=3000

# ---- المزامنة ----
SYNC_INTERVAL_MINUTES=5

# ---- جيرا (اختياري؛ يمكن ضبطه لاحقاً من الإعدادات داخل التطبيق) ----
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_JQL=ORDER BY updated DESC
